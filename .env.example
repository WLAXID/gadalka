# Скопируй в .env и заполни значениями
# .env в .gitignore — никогда не коммитим!

# ===== Polygon RPC =====
# Chainstack — основной (archive node для historical event logs)
CHAINSTACK_POLYGON_RPC=https://nd-XXX-XXX-XXX.polygon-mainnet.chainstack.com/AUTH_KEY

# Alchemy — backup
ALCHEMY_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_API_KEY=

# ===== Аналитика =====
# Dune Analytics — главный источник historical Polymarket data
DUNE_API_KEY=

# Polygon.io — reference price feed (BTC/ETH для крипто-рынков)
POLYGON_IO_API_KEY=

# ===== Новости и web =====
# Tavily — search + content extraction
TAVILY_API_KEY=

# NewsAPI — заголовки и статьи
NEWSAPI_KEY=

# Perplexity — LLM с web search (для news → P(yes) features)
PERPLEXITY_API_KEY=

# ===== Котировки спорта (опционально, Фаза 1+) =====
# The Odds API — для арб с sport-категорией Polymarket
ODDS_API_KEY=

# ===== Telegram bot (Фаза 2 paper) =====
# Бот @YourBot, получить через @BotFather
TG_BOT_TOKEN=
# Твой Telegram user ID (узнать через @userinfobot). Только этот id допущен.
TG_OWNER_ID=

# ===== Paper trader runtime =====
PAPER_DB_PATH=/app/data/paper.duckdb
PAPER_LOG_LEVEL=INFO
PAPER_ETL_INTERVAL_S=900          # как часто сканируем рынки (сек)
PAPER_RESOLVE_INTERVAL_S=3600     # как часто проверяем резолвы (сек)
PAPER_DAILY_REPORT_TIME=23:59     # время ежедневного отчёта (UTC, HH:MM)

# Стратегия H1 baseline
PAPER_STRATEGY_LOW=0.50           # минимальная цена YES @ T-24h для входа
PAPER_STRATEGY_HIGH=0.85          # максимальная цена YES @ T-24h для входа
