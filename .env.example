# Скопируй в .env и заполни значениями
# .env в .gitignore — никогда не коммитим!

# ===== Polygon RPC =====
# Chainstack — основной (archive node для historical event logs)
CHAINSTACK_POLYGON_RPC=https://nd-XXX-XXX-XXX.polygon-mainnet.chainstack.com/AUTH_KEY

# Alchemy — backup
ALCHEMY_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_API_KEY=

# ===== Аналитика =====
# Dune Analytics — главный источник historical Polymarket data
DUNE_API_KEY=

# Polygon.io — reference price feed (BTC/ETH для крипто-рынков)
POLYGON_IO_API_KEY=

# ===== Новости и web =====
# Tavily — search + content extraction
TAVILY_API_KEY=

# NewsAPI — заголовки и статьи
NEWSAPI_KEY=

# Perplexity — LLM с web search (для news → P(yes) features)
PERPLEXITY_API_KEY=

# ===== Котировки спорта (опционально, Фаза 1+) =====
# The Odds API — для арб с sport-категорией Polymarket
ODDS_API_KEY=
