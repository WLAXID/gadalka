# Скопируй в .env и заполни значениями
# .env в .gitignore — никогда не коммитим!

# ===== Polygon RPC =====
# Chainstack — основной (archive node для historical event logs)
CHAINSTACK_POLYGON_RPC=https://nd-XXX-XXX-XXX.polygon-mainnet.chainstack.com/AUTH_KEY

# Alchemy — backup
ALCHEMY_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_API_KEY=

# ===== Аналитика =====
# Dune Analytics — главный источник historical Polymarket data
DUNE_API_KEY=

# Polygon.io — reference price feed (BTC/ETH для крипто-рынков)
POLYGON_IO_API_KEY=

# ===== Новости и web =====
# Tavily — search + content extraction
TAVILY_API_KEY=

# NewsAPI — заголовки и статьи
NEWSAPI_KEY=

# Perplexity — LLM с web search (для news → P(yes) features)
PERPLEXITY_API_KEY=

# ===== Котировки спорта (опционально, Фаза 1+) =====
# The Odds API — для арб с sport-категорией Polymarket
ODDS_API_KEY=

# ===== Telegram bot (Фаза 2 paper) =====
# Бот @YourBot, получить через @BotFather
TG_BOT_TOKEN=
# Твой Telegram user ID (узнать через @userinfobot). Только этот id допущен.
TG_OWNER_ID=

# ===== Paper trader runtime =====
PAPER_DB_PATH=/app/data/paper.duckdb
PAPER_LOG_LEVEL=INFO
PAPER_ETL_INTERVAL_S=900          # как часто сканируем рынки (сек)
PAPER_RESOLVE_INTERVAL_S=3600     # как часто проверяем резолвы (сек)
PAPER_DAILY_REPORT_TIME=23:59     # время ежедневного отчёта (UTC, HH:MM)

# Стратегия H1 baseline
PAPER_STRATEGY_LOW=0.50           # минимальная цена YES для входа
PAPER_STRATEGY_HIGH=0.85          # максимальная цена YES для входа

# ===== Phase 2 — long-run resilience =====
# Trace: каждые N сек снимаем mid/bid/ask для всех pending → траектории
PAPER_TRACE_INTERVAL_S=3600       # 1 час
# Heartbeat: если УСПЕШНЫЙ scan молчит > threshold → push в TG
PAPER_HEARTBEAT_THRESHOLD_S=3600  # 1 час
PAPER_HEARTBEAT_THROTTLE_S=21600  # не чаще раза в 6 часов
# Backup: ежедневный дамп БД в backup_dir, rotation N дней
PAPER_BACKUP_TIME=03:00           # UTC, HH:MM (валидируется на старте)
PAPER_BACKUP_DIR=/app/data/backups
PAPER_BACKUP_RETENTION_DAYS=14
# Cleanup scan_dump старше N дней (растёт ~2k записей/день)
PAPER_SCAN_DUMP_RETENTION_DAYS=45
# Telegram watchdog: каждые N сек getMe(), рестарт polling если умер
PAPER_TG_WATCHDOG_INTERVAL_S=300  # 5 минут
# Корректность выборки
PAPER_MAX_MARKET_TTL_DAYS=60      # пропускать рынки с endDate > now+N дней
PAPER_STUCK_PENDING_AFTER_DAYS=7  # warning если pending после endDate+N
PAPER_PENDING_GROWTH_ALERT=200    # alert в daily если pending > N
